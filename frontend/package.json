{
  "name": "inpr-next-sanity-starter",
  "private": true,
  "scripts": {
    "build": "next build",
    "predev": "npm run typegen",
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "format": "npx prettier --write . --ignore-path .gitignore",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "typegen": "sanity typegen generate"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@next/env": "^16.2.0",
    "@next/third-parties": "^16.2.0",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "2.0.3",
    "@sanity/util": "^5.17.1",
    "classnames": "2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "focus-trap-react": "^12.0.0",
    "gsap": "^3.14.2",
    "hamo": "latest",
    "hls.js": "^1.6.15",
    "lenis": "^1.3.19",
    "next": "^16.2.0",
    "next-sanity": "^12.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-player": "^3.4.0",
    "sanity": "^5.17.1",
    "sanity-image": "^1.1.0",
    "sharp": "^0.34.5",
    "sonner": "2.0.7",
